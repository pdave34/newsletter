<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f6f9;font-family:Arial,Helvetica,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f4f6f9;">
  <tr>
    <td align="center" style="padding:24px 16px;">

      <!-- Header -->
      <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">
        <tr>
          <td style="background-color:#1a1a2e;border-radius:8px 8px 0 0;padding:32px 40px;text-align:center;">
            <h1 style="margin:0;color:#ffffff;font-size:24px;font-weight:700;letter-spacing:-0.5px;">
              AI &amp; Data Engineering
            </h1>
            <p style="margin:8px 0 0;color:#a0a8c0;font-size:14px;">
              {{ generated_at }} &mdash; {{ article_count }} articles
            </p>
          </td>
        </tr>
      </table>

      <!-- Articles -->
      <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background-color:#ffffff;">

        {% for article in articles %}
        <tr>
          <td style="padding:24px 40px;border-bottom:1px solid #eef0f4;">
            <!-- Source badge -->
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="background-color:#eef4ff;border-radius:4px;padding:2px 8px;">
                  <span style="font-size:11px;font-weight:600;color:#4a6cf7;text-transform:uppercase;letter-spacing:0.5px;">
                    {{ article.source }}
                  </span>
                </td>
              </tr>
            </table>
            <!-- Title -->
            <h2 style="margin:10px 0 8px;font-size:17px;font-weight:600;line-height:1.4;">
              <a href="{{ article.url }}" style="color:#1a1a2e;text-decoration:none;">
                {{ article.title }}
              </a>
            </h2>
            <!-- Summary -->
            {% if article.summary %}
            <p style="margin:0 0 10px;font-size:14px;color:#555b6e;line-height:1.6;">
              {{ article.summary }}{% if article.summary|length >= 280 %}&hellip;{% endif %}
            </p>
            {% endif %}
            <!-- Meta -->
            <p style="margin:0;font-size:12px;color:#9aa0b0;">
              {{ article.published.strftime('%b %d, %Y') }}
              &nbsp;&bull;&nbsp;
              <a href="{{ article.url }}" style="color:#4a6cf7;text-decoration:none;">Read more &rarr;</a>
            </p>
          </td>
        </tr>
        {% endfor %}

      </table>

      <!-- Footer -->
      <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">
        <tr>
          <td style="background-color:#f4f6f9;border-top:1px solid #dde1ea;padding:20px 40px;text-align:center;">
            <p style="margin:0;font-size:12px;color:#9aa0b0;">
              Generated automatically &mdash; curated from engineering blogs and news sources.
            </p>
          </td>
        </tr>
      </table>

    </td>
  </tr>
</table>

</body>
</html>
